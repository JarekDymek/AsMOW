PORT=3000

# Wybierz dostawcę: gemini, openai albo anthropic.
LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI, jeżeli kiedyś użyjesz OpenAI zamiast Gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic, jeżeli kiedyś użyjesz Anthropic zamiast OpenAI
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Domena PWA, jeżeli frontend jest hostowany osobno. Dla testów może zostać *.
ALLOWED_ORIGINS=*

MAX_TOKENS=1400
TEMPERATURE=0.2
RATE_LIMIT_PER_MINUTE=30

# Biezace informacje z poczty dyrektora internatu
CURRENT_INFO_IMAP_HOST=imap.gmail.com
CURRENT_INFO_IMAP_PORT=993
CURRENT_INFO_IMAP_SECURE=true
CURRENT_INFO_IMAP_MAILBOX=INBOX
CURRENT_INFO_IMAP_USER=twoj-adres@gmail.com
CURRENT_INFO_IMAP_PASSWORD=16-znakowe-haslo-aplikacyjne
CURRENT_INFO_FROM=dgorski5@wp.pl
CURRENT_INFO_SINCE=2026-01-01
CURRENT_INFO_SYNC_TOKEN=wlasny-dlugi-token
